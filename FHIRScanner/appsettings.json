{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OcrProcessing": {
    "PythonExecutable": "python",
    "ScriptRelativePath": "ocr_to_fhir\\ocr_layout.py",
    "OutputRelativePath": "Storage\\OcrResults",
    "Language": "eng",
    "PageSegmentationMode": 6,
    "MinimumConfidence": 35
  },
  "OpenAI": {
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1/",
    "Model": "gpt-5.4",
    "Organization": "",
    "AllowMissingApiKeyForLocalhost": true
  },
  "FhirDrafting": {
    "OutputRelativePath": "Storage\\FhirDrafts",
    "MaxLinesToSend": 28,
    "MaxLineTextLength": 110,
    "MaxFullTextChars": 1500,
    "RetryMaxLinesToSend": 16,
    "RetryMaxLineTextLength": 80,
    "RetryMaxFullTextChars": 800,
    "EmergencyMaxLinesToSend": 8,
    "EmergencyMaxLineTextLength": 60,
    "EmergencyMaxFullTextChars": 350
  },
  "AllowedHosts": "*"
}
