@page "/"
@rendermode InteractiveServer
@inject IWebHostEnvironment Environment
@inject ILogger<Home> Logger
@inject FHIRScanner.Services.OcrProcessingService OcrProcessingService
@inject FHIRScanner.Services.LabReportStructuringService LabReportStructuringService
@inject FHIRScanner.Services.FhirDraftingService FhirDraftingService

<PageTitle>FHIRScanner</PageTitle>

<section class="page-header">
    <div>
        <span class="section-kicker">Clinical OCR</span>
        <h1>FHIR Scanner</h1>
    </div>

    <div class="header-status">
        <div>
            <span class="guidance-label">Selected</span>
            <strong>@UploadedFiles.Count</strong>
        </div>
        <div>
            <span class="guidance-label">Status</span>
            <strong>@GetProcessingSummary()</strong>
        </div>
        <div>
            <span class="guidance-label">Storage</span>
            <strong>@StorageFolderDisplay</strong>
        </div>
    </div>
</section>

<section class="upload-panel">
    <div class="upload-panel-header">
        <div>
            <span class="panel-kicker">Document intake</span>
            <h2>Upload lab image</h2>
        </div>
        <span class="format-note">PNG, JPG, TIFF, BMP, WEBP</span>
    </div>

    <label class="upload-dropzone" for="document-upload">
        <InputFile id="document-upload"
                   class="upload-input"
                   OnChange="HandleFilesSelected"
                   multiple
                   accept=".png,.jpg,.jpeg,.tif,.tiff,.bmp,.webp,image/png,image/jpeg,image/jpg,image/tiff,image/bmp,image/webp" />

        <div class="upload-icon" aria-hidden="true">
            <span></span>
            <span></span>
        </div>

        <strong>Select or drop images</strong>
        <span>Max @FormatFileSize(MaxFileSizeBytes) per file</span>
    </label>

    @if (!string.IsNullOrWhiteSpace(UploadMessage))
    {
        <div class="upload-feedback upload-feedback-success">@UploadMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(UploadError))
    {
        <div class="upload-feedback upload-feedback-error">@UploadError</div>
    }
</section>

<section class="workspace-grid" id="results">
    <div class="selection-card">
        <div class="section-heading">
            <div>
                <span class="section-kicker">Current batch</span>
                <h2>Case files</h2>
            </div>
            <div class="section-actions">
                <span class="section-pill">@FormatFileCount(UploadedFiles.Count)</span>
                <button class="action-button action-button-primary"
                        @onclick="RunProcessingAsync"
                        disabled="@(UploadedFiles.Count == 0 || IsProcessing || IsGeneratingFhir)">
                    @(IsProcessing ? "Running OCR..." : "Run OCR")
                </button>
                <button class="action-button action-button-secondary"
                        @onclick="RunFhirDraftingAsync"
                        disabled="@(!CanGenerateFhirDrafts() || IsProcessing || IsGeneratingFhir)">
                    @(IsGeneratingFhir ? "Generating FHIR..." : "Generate FHIR Draft")
                </button>
            </div>
        </div>

        @if (UploadedFiles.Count == 0)
        {
            <div class="empty-state">
                <strong>No files loaded</strong>
                <p>Awaiting lab image upload.</p>
            </div>
        }
        else
        {
            <div class="file-list">
                @foreach (var file in UploadedFiles)
                {
                    <article class="file-row file-row-rich">
                        <div class="file-badge">@GetFileBadge(file)</div>
                        <div class="file-meta">
                            <strong>@file.OriginalName</strong>
                            <span>@file.Format - @FormatFileSize(file.Size)</span>
                            <span>Saved as @file.StoredName</span>
                            <span>@file.RelativePath</span>
                            <span class="status-chip @GetStatusClass(file.Status)">@file.Status</span>

                            @if (file.LineCount > 0 || file.WordCount > 0)
                            {
                                <div class="ocr-summary">
                                    <span class="result-meta">Lines: @file.LineCount</span>
                                    <span class="result-meta">Words: @file.WordCount</span>
                                    <span class="result-meta">Avg confidence: @file.AverageConfidence.ToString("0.0")</span>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.OutputRelativePath))
                            {
                                <span class="result-meta">OCR JSON: @file.OutputRelativePath</span>
                            }

                            @if (file.StructuredReport is not null)
                            {
                                <div class="ocr-summary">
                                    <span class="result-meta">Sections: @file.StructuredReport.Sections.Count</span>
                                    <span class="result-meta">Rows: @GetStructuredRowCount(file)</span>
                                    <span class="result-meta">Schema warnings: @file.StructuredReport.Warnings.Count</span>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.FhirOutputRelativePath))
                            {
                                <span class="result-meta">FHIR draft JSON: @file.FhirOutputRelativePath</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.FhirStatus))
                            {
                                <span class="result-meta">FHIR status: @file.FhirStatus</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.LastError))
                            {
                                <div class="result-preview result-preview-error">
                                    <strong>Processing error</strong>
                                    <p>@file.LastError</p>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.FhirError))
                            {
                                <div class="result-preview result-preview-error">
                                    <strong>FHIR drafting error</strong>
                                    <p>@file.FhirError</p>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(file.FullText))
                            {
                                <div class="ocr-results-grid">
                                    <div class="ocr-canvas-card">
                                        <div class="visual-header">
                                            <strong>Detected lines over image</strong>
                                            <span>@file.ImageWidth x @file.ImageHeight px</span>
                                        </div>

                                        <div class="ocr-canvas">
                                            <img class="ocr-image" src="@GetUploadedImageUrl(file)" alt="@file.OriginalName" />
                                            <div class="ocr-overlay">
                                                @foreach (var line in file.Lines)
                                                {
                                                    <div class="ocr-box"
                                                         title="@($"Line {line.LineIndex}: {line.Text} ({line.Confidence:0.0})")"
                                                         style="@BuildBoxStyle(file, line.Left, line.Top, line.Width, line.Height)"></div>
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <div class="ocr-text-card">
                                        <div class="visual-header">
                                            <strong>Recognized text</strong>
                                            <span>Line-preserving output</span>
                                        </div>
                                        <pre class="ocr-text-output">@file.FullText</pre>
                                    </div>
                                </div>

                                <div class="ocr-coordinates-card">
                                    <div class="visual-header">
                                        <strong>Line coordinates</strong>
                                        <span>Top 30 lines</span>
                                    </div>

                                    <div class="coordinate-list">
                                        @foreach (var line in file.Lines.Take(30))
                                        {
                                            <div class="coordinate-row">
                                                <strong>L@line.LineIndex: @line.Text</strong>
                                                <span>conf @line.Confidence.ToString("0.0")</span>
                                                <span>page @line.Page, block @line.Block, paragraph @line.Paragraph, line @line.Line</span>
                                                <span>x @line.Left, y @line.Top, w @line.Width, h @line.Height</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <details class="result-json">
                                    <summary>View raw OCR JSON</summary>
                                    <pre>@file.RawJson</pre>
                                </details>

                                @if (file.StructuredReport is not null)
                                {
                                    <div class="ocr-coordinates-card">
                                        <div class="visual-header">
                                            <strong>Structured lab report</strong>
                                            <span>@GetStructuredRowCount(file) extracted row@(GetStructuredRowCount(file) == 1 ? string.Empty : "s")</span>
                                        </div>

                                        <div class="coordinate-list">
                                            @foreach (var reportSection in file.StructuredReport.Sections.Where(section => section.Rows.Count > 0))
                                            {
                                                <div class="coordinate-row">
                                                    <strong>@reportSection.Name</strong>
                                                    <span>@reportSection.Rows.Count row@(reportSection.Rows.Count == 1 ? string.Empty : "s")</span>
                                                    <span>@string.Join(" | ", reportSection.Rows.Take(3).Select(row => $"{row.TestName}: {row.NumericValueText ?? row.ResultText} {row.NormalizedUnit ?? row.UnitText}".Trim()))</span>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <details class="result-json">
                                        <summary>View structured lab report JSON</summary>
                                        <pre>@file.StructuredReportJson</pre>
                                    </details>
                                }
                            }

                            @if (file.FhirResources.Count > 0 || file.FhirWarnings.Count > 0 || file.FhirMissingFields.Count > 0)
                            {
                                <div class="fhir-card">
                                    <div class="visual-header">
                                        <strong>FHIR draft</strong>
                                        <span>@file.FhirResources.Count resource@(file.FhirResources.Count == 1 ? string.Empty : "s")</span>
                                    </div>

                                    @if (file.FhirWarnings.Count > 0)
                                    {
                                        <div class="fhir-note-group">
                                            <strong>Warnings</strong>
                                            <ul class="fhir-list">
                                                @foreach (var warning in file.FhirWarnings)
                                                {
                                                    <li>@warning</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    @if (file.FhirMissingFields.Count > 0)
                                    {
                                        <div class="fhir-note-group">
                                            <strong>Missing fields</strong>
                                            <ul class="fhir-list">
                                                @foreach (var missingField in file.FhirMissingFields)
                                                {
                                                    <li>@missingField</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    <div class="fhir-resource-list">
                                        @foreach (var resource in file.FhirResources)
                                        {
                                            <details class="result-json">
                                                <summary>@resource.ResourceType - @resource.Rationale</summary>
                                                <pre>@resource.Resource.GetRawText()</pre>
                                            </details>
                                        }
                                    </div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(file.FhirRawJson))
                                {
                                    <details class="result-json">
                                        <summary>View raw FHIR draft JSON</summary>
                                        <pre>@file.FhirRawJson</pre>
                                    </details>
                                }
                            }
                        </div>
                        <div class="file-actions">
                            <button class="file-action-button file-action-danger"
                                    @onclick="() => DeleteUploadedFileAsync(file)"
                                    disabled="@IsProcessing">
                                Delete
                            </button>
                        </div>
                    </article>
                }
            </div>

            <div class="selection-summary">
                <div>
                    <span class="guidance-label">Total size</span>
                    <strong>@FormatFileSize(UploadedFiles.Sum(file => file.Size))</strong>
                </div>
                <div>
                    <span class="guidance-label">Workflow status</span>
                    <strong>@GetProcessingSummary()</strong>
                </div>
                <div>
                    <span class="guidance-label">Upload folder</span>
                    <strong>@StorageFolderDisplay</strong>
                </div>
            </div>
        }
    </div>

</section>

@code {
    private const int MaxAllowedFiles = 20;
    private const long MaxFileSizeBytes = 50L * 1024 * 1024;

    private static readonly HashSet<string> SupportedImageExtensions =
    [
        ".png",
        ".jpg",
        ".jpeg",
        ".tif",
        ".tiff",
        ".bmp",
        ".webp",
    ];

    private readonly List<UploadedDocument> UploadedFiles = [];
    private string? UploadMessage;
    private string? UploadError;
    private bool IsProcessing;
    private bool IsGeneratingFhir;

    private string StorageFolderDisplay => Path.Combine("Storage", "Uploads");

    private async Task HandleFilesSelected(InputFileChangeEventArgs args)
    {
        UploadMessage = null;
        UploadError = null;

        var selectedFiles = args.GetMultipleFiles(MaxAllowedFiles);
        if (selectedFiles.Count == 0)
        {
            return;
        }

        var uploadRoot = Path.Combine(Environment.ContentRootPath, "Storage", "Uploads");
        Directory.CreateDirectory(uploadRoot);

        var savedFiles = new List<UploadedDocument>();

        foreach (var file in selectedFiles)
        {
            try
            {
                var originalName = Path.GetFileName(file.Name);
                var extension = Path.GetExtension(originalName).ToLowerInvariant();
                if (!SupportedImageExtensions.Contains(extension))
                {
                    UploadError = $"{originalName} was skipped because OCR-only mode currently accepts images only.";
                    continue;
                }

                var safeStem = CreateSafeFileStem(Path.GetFileNameWithoutExtension(originalName));
                var storedName = $"{DateTime.UtcNow:yyyyMMddHHmmssfff}_{safeStem}_{Guid.NewGuid():N}{extension}";
                var destinationPath = Path.Combine(uploadRoot, storedName);

                await using var readStream = file.OpenReadStream(MaxFileSizeBytes);
                await using var writeStream = new FileStream(destinationPath, FileMode.CreateNew, FileAccess.Write, FileShare.None);
                await readStream.CopyToAsync(writeStream);

                savedFiles.Add(new UploadedDocument(
                    originalName,
                    storedName,
                    GetDisplayFormat(originalName),
                    file.Size,
                    Path.Combine(StorageFolderDisplay, storedName),
                    "Saved"));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to save uploaded image {FileName}", file.Name);
                UploadError = $"One or more images could not be saved. Maximum size per file is {FormatFileSize(MaxFileSizeBytes)}.";
            }
        }

        if (savedFiles.Count > 0)
        {
            UploadedFiles.AddRange(savedFiles);
            UploadMessage = $"{savedFiles.Count} image{(savedFiles.Count == 1 ? string.Empty : "s")} saved to {StorageFolderDisplay}.";
        }
    }

    private async Task DeleteUploadedFileAsync(UploadedDocument file)
    {
        UploadMessage = null;
        UploadError = null;

        try
        {
            var targetPath = Path.Combine(Environment.ContentRootPath, "Storage", "Uploads", file.StoredName);
            if (File.Exists(targetPath))
            {
                File.Delete(targetPath);
            }

            if (!string.IsNullOrWhiteSpace(file.OutputRelativePath))
            {
                var outputPath = Path.Combine(Environment.ContentRootPath, file.OutputRelativePath);
                if (File.Exists(outputPath))
                {
                    File.Delete(outputPath);
                }
            }

            if (!string.IsNullOrWhiteSpace(file.FhirOutputRelativePath))
            {
                var fhirOutputPath = Path.Combine(Environment.ContentRootPath, file.FhirOutputRelativePath);
                if (File.Exists(fhirOutputPath))
                {
                    File.Delete(fhirOutputPath);
                }
            }

            UploadedFiles.Remove(file);
            UploadMessage = $"{file.OriginalName} was deleted from {StorageFolderDisplay}.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete uploaded image {FileName}", file.OriginalName);
            UploadError = $"Could not delete {file.OriginalName}.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RunProcessingAsync()
    {
        if (UploadedFiles.Count == 0 || IsProcessing)
        {
            return;
        }

        UploadMessage = null;
        UploadError = null;
        IsProcessing = true;

        try
        {
            foreach (var file in UploadedFiles)
            {
                file.Status = "Queued";
                file.OutputRelativePath = null;
                file.RawJson = null;
                file.FullText = null;
                file.ImageWidth = 0;
                file.ImageHeight = 0;
                file.AverageConfidence = 0;
                file.LineCount = 0;
                file.WordCount = 0;
                file.Lines.Clear();
                file.LayoutResult = null;
                file.StructuredReport = null;
                file.StructuredReportJson = null;
                file.LastError = null;
                ResetFhirDraft(file);
            }

            await InvokeAsync(StateHasChanged);

            var successCount = 0;
            var failedCount = 0;

            foreach (var file in UploadedFiles)
            {
                file.Status = "Processing";
                await InvokeAsync(StateHasChanged);

                var result = await OcrProcessingService.ProcessAsync(file.StoredName);
                file.Status = result.Status;
                file.OutputRelativePath = result.OutputRelativePath;
                file.RawJson = result.RawJson;
                file.LastError = result.ErrorMessage;

                if (result.Layout is not null)
                {
                    file.FullText = result.Layout.FullText;
                    file.ImageWidth = result.Layout.ImageWidth;
                    file.ImageHeight = result.Layout.ImageHeight;
                    file.AverageConfidence = result.Layout.AverageConfidence;
                    file.LineCount = result.Layout.LineCount;
                    file.WordCount = result.Layout.WordCount;
                    file.Lines.AddRange(result.Layout.Lines);
                    file.LayoutResult = result.Layout;

                    var structuredResult = LabReportStructuringService.Parse(result.Layout);
                    file.StructuredReport = structuredResult.Report;
                    file.StructuredReportJson = structuredResult.RawJson;

                    if (!structuredResult.Succeeded && !string.IsNullOrWhiteSpace(structuredResult.ErrorMessage))
                    {
                        file.LastError = structuredResult.ErrorMessage;
                    }
                }

                if (result.Succeeded)
                {
                    successCount++;
                }
                else
                {
                    failedCount++;
                }

                await InvokeAsync(StateHasChanged);
            }

            UploadMessage = $"{successCount} image{(successCount == 1 ? string.Empty : "s")} processed for OCR inspection."
                + (failedCount > 0 ? $" {failedCount} image{(failedCount == 1 ? string.Empty : "s")} need attention." : string.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed while running OCR processing");
            UploadError = "OCR processing could not be completed.";
        }
        finally
        {
            IsProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunFhirDraftingAsync()
    {
        if (!CanGenerateFhirDrafts() || IsGeneratingFhir || IsProcessing)
        {
            return;
        }

        UploadMessage = null;
        UploadError = null;
        IsGeneratingFhir = true;

        try
        {
            var successCount = 0;
            var failedCount = 0;

            foreach (var file in UploadedFiles.Where(file => GetStructuredRowCount(file) > 0))
            {
                ResetFhirDraft(file);
                file.FhirStatus = "Generating FHIR";
                await InvokeAsync(StateHasChanged);

                var result = await FhirDraftingService.GenerateAsync(file.StoredName, file.StructuredReport);
                file.FhirStatus = result.Status;
                file.FhirOutputRelativePath = result.OutputRelativePath;
                file.FhirRawJson = result.RawJson;
                file.FhirError = result.ErrorMessage;

                if (result.Payload is not null)
                {
                    file.FhirResources.AddRange(result.Payload.Resources);
                    file.FhirWarnings.AddRange(result.Payload.Warnings);
                    file.FhirMissingFields.AddRange(result.Payload.MissingFields);
                }

                if (result.Succeeded)
                {
                    successCount++;
                }
                else
                {
                    failedCount++;
                }

                await InvokeAsync(StateHasChanged);
            }

            UploadMessage = $"{successCount} OCR result{(successCount == 1 ? string.Empty : "s")} converted into draft FHIR output."
                + (failedCount > 0 ? $" {failedCount} draft{(failedCount == 1 ? string.Empty : "s")} need attention." : string.Empty);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed while generating FHIR drafts");
            UploadError = "FHIR draft generation could not be completed.";
        }
        finally
        {
            IsGeneratingFhir = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatFileCount(int count) => count switch
    {
        0 => "Waiting for upload",
        1 => "1 image selected",
        _ => $"{count} images selected"
    };

    private static string FormatFileSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double size = bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:0.#} {units[unitIndex]}";
    }

    private static string GetDisplayFormat(string fileName)
    {
        var extension = Path.GetExtension(fileName);
        return string.IsNullOrWhiteSpace(extension) ? "Unknown format" : extension.TrimStart('.').ToUpperInvariant();
    }

    private static string GetFileBadge(UploadedDocument file)
    {
        var extension = Path.GetExtension(file.OriginalName).ToLowerInvariant();

        return extension switch
        {
            ".png" => "PNG",
            ".jpg" or ".jpeg" => "JPG",
            ".tif" or ".tiff" => "TIF",
            ".bmp" => "BMP",
            ".webp" => "WEBP",
            _ => "IMG"
        };
    }

    private static string GetStatusClass(string status) => status switch
    {
        "Saved" => "status-saved",
        "Queued" => "status-queued",
        "Processing" => "status-processing",
        "OCR ready" => "status-ready",
        "OCR failed" or "Missing file" or "Missing output" or "OCR unavailable" or "Unsupported file" or "Invalid output" => "status-error",
        _ => string.Empty
    };

    private string GetProcessingSummary()
    {
        if (IsProcessing)
        {
            return "Running OCR";
        }

        if (IsGeneratingFhir)
        {
            return "Generating FHIR drafts";
        }

        if (UploadedFiles.Count == 0)
        {
            return "Waiting for upload";
        }

        if (UploadedFiles.Any(file => file.Status is "OCR failed" or "Missing file" or "Missing output" or "OCR unavailable" or "Unsupported file" or "Invalid output"))
        {
            return "Completed with issues";
        }

        return UploadedFiles.All(file => file.Status == "OCR ready")
            ? "OCR results ready"
            : "Saved to private storage";
    }

    private static string CreateSafeFileStem(string rawFileName)
    {
        if (string.IsNullOrWhiteSpace(rawFileName))
        {
            return "image";
        }

        var invalidChars = Path.GetInvalidFileNameChars();
        var cleaned = new string(rawFileName
            .Select(character => invalidChars.Contains(character) ? '_' : character)
            .ToArray());

        cleaned = cleaned.Replace(' ', '_');
        return string.IsNullOrWhiteSpace(cleaned) ? "image" : cleaned;
    }

    private static string GetUploadedImageUrl(UploadedDocument file) => $"/uploads/{Uri.EscapeDataString(file.StoredName)}";

    private bool CanGenerateFhirDrafts() => UploadedFiles.Any(file => GetStructuredRowCount(file) > 0);

    private static int GetStructuredRowCount(UploadedDocument file)
        => file.StructuredReport?.Sections.Sum(section => section.Rows.Count) ?? 0;

    private static void ResetFhirDraft(UploadedDocument file)
    {
        file.FhirStatus = null;
        file.FhirOutputRelativePath = null;
        file.FhirRawJson = null;
        file.FhirError = null;
        file.FhirResources.Clear();
        file.FhirWarnings.Clear();
        file.FhirMissingFields.Clear();
    }

    private static string BuildBoxStyle(UploadedDocument file, int left, int top, int width, int height)
    {
        if (file.ImageWidth <= 0 || file.ImageHeight <= 0)
        {
            return string.Empty;
        }

        return System.FormattableString.Invariant(
            $"left:{left * 100d / file.ImageWidth:F3}%;top:{top * 100d / file.ImageHeight:F3}%;width:{width * 100d / file.ImageWidth:F3}%;height:{height * 100d / file.ImageHeight:F3}%;");
    }

    private sealed class UploadedDocument
    {
        public UploadedDocument(string originalName, string storedName, string format, long size, string relativePath, string status)
        {
            OriginalName = originalName;
            StoredName = storedName;
            Format = format;
            Size = size;
            RelativePath = relativePath;
            Status = status;
        }

        public string OriginalName { get; }
        public string StoredName { get; }
        public string Format { get; }
        public long Size { get; }
        public string RelativePath { get; }
        public string Status { get; set; }
        public string? OutputRelativePath { get; set; }
        public string? RawJson { get; set; }
        public string? FullText { get; set; }
        public int ImageWidth { get; set; }
        public int ImageHeight { get; set; }
        public double AverageConfidence { get; set; }
        public int LineCount { get; set; }
        public int WordCount { get; set; }
        public List<FHIRScanner.Services.OcrLineBox> Lines { get; } = [];
        public FHIRScanner.Services.OcrLayoutResult? LayoutResult { get; set; }
        public FHIRScanner.Services.StructuredLabReport? StructuredReport { get; set; }
        public string? StructuredReportJson { get; set; }
        public string? LastError { get; set; }
        public string? FhirStatus { get; set; }
        public string? FhirOutputRelativePath { get; set; }
        public string? FhirRawJson { get; set; }
        public string? FhirError { get; set; }
        public List<FHIRScanner.Services.FhirDraftResource> FhirResources { get; } = [];
        public List<string> FhirWarnings { get; } = [];
        public List<string> FhirMissingFields { get; } = [];
    }
}
